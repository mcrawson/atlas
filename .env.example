# =============================================================================
# ATLAS Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Core AI Providers (at least one required)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...

# -----------------------------------------------------------------------------
# Web Search (for research capabilities)
# -----------------------------------------------------------------------------
# Tavily - Best for AI agents, clean results
# Get from: https://tavily.com
TAVILY_API_KEY=tvly-...

# Serper - Google search results (optional, fallback)
# Get from: https://serper.dev
SERPER_API_KEY=...

# -----------------------------------------------------------------------------
# GitHub (for code repository integration)
# -----------------------------------------------------------------------------
# Get from: https://github.com/settings/tokens
# Scopes needed: repo, read:user
GITHUB_TOKEN=ghp_...

# -----------------------------------------------------------------------------
# Slack (for notifications and two-way integration)
# -----------------------------------------------------------------------------
# Get from: https://api.slack.com/apps → Your App → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# =============================================================================
# PLATFORM INTEGRATIONS
# =============================================================================

# -----------------------------------------------------------------------------
# 🎨 Canva (covers, icons, graphics)
# -----------------------------------------------------------------------------
# 1. Go to: https://www.canva.com/developers/
# 2. Create an app in the Developer Portal
# 3. Get your API key from the app settings
CANVA_API_KEY=...
CANVA_BRAND_ID=...  # Optional: for brand kit access

# -----------------------------------------------------------------------------
# 📝 Google Docs (documents, books)
# -----------------------------------------------------------------------------
# 1. Go to: https://console.cloud.google.com/
# 2. Create a project and enable Google Docs API
# 3. Create OAuth 2.0 credentials
# 4. Download credentials JSON
GOOGLE_CREDENTIALS_PATH=/path/to/credentials.json
GOOGLE_ACCESS_TOKEN=...  # Generated via OAuth flow

# -----------------------------------------------------------------------------
# 🖼️ Figma (UI designs)
# -----------------------------------------------------------------------------
# 1. Go to: https://www.figma.com/developers/api
# 2. Create a personal access token
FIGMA_API_TOKEN=figd_...

# -----------------------------------------------------------------------------
# 🍎 Apple App Store Connect
# -----------------------------------------------------------------------------
# 1. Go to: https://appstoreconnect.apple.com/access/api
# 2. Create an API key (requires Admin role)
# 3. Download the .p8 private key file
APP_STORE_ISSUER_ID=...  # Your issuer ID (UUID format)
APP_STORE_KEY_ID=...  # Key ID from App Store Connect
APP_STORE_PRIVATE_KEY_PATH=/path/to/AuthKey_XXXX.p8

# -----------------------------------------------------------------------------
# 🤖 Google Play Store
# -----------------------------------------------------------------------------
# 1. Go to: https://play.google.com/console/developers
# 2. Setup → API access → Create service account
# 3. Download service account JSON
# 4. Grant permissions to the service account
GOOGLE_PLAY_SERVICE_ACCOUNT=/path/to/service-account.json
ANDROID_PACKAGE_NAME=com.yourcompany.yourapp

# -----------------------------------------------------------------------------
# ▲ Vercel (web deployment)
# -----------------------------------------------------------------------------
# 1. Go to: https://vercel.com/account/tokens
# 2. Create a new token
VERCEL_TOKEN=...
VERCEL_TEAM_ID=...  # Optional: for team deployments

# -----------------------------------------------------------------------------
# 📦 npm (JavaScript packages)
# -----------------------------------------------------------------------------
# 1. Run: npm login
# 2. Run: npm token create
# Or go to: https://www.npmjs.com/settings/~/tokens
NPM_TOKEN=npm_...

# -----------------------------------------------------------------------------
# 🐍 PyPI (Python packages)
# -----------------------------------------------------------------------------
# 1. Go to: https://pypi.org/manage/account/token/
# 2. Create an API token
# For testing, use TestPyPI: https://test.pypi.org/manage/account/token/
PYPI_TOKEN=pypi-...
USE_TEST_PYPI=false  # Set to true for testing

# =============================================================================
# QUICK SETUP CHECKLIST
# =============================================================================
#
# Minimum viable setup:
# ☐ One AI provider (OPENAI_API_KEY or ANTHROPIC_API_KEY)
# ☐ GITHUB_TOKEN (for code export)
#
# For app projects:
# ☐ CANVA_API_KEY (icons, graphics)
# ☐ APP_STORE credentials (iOS)
# ☐ GOOGLE_PLAY credentials (Android)
#
# For book projects:
# ☐ CANVA_API_KEY (covers)
# ☐ GOOGLE_ACCESS_TOKEN (Google Docs)
# ☐ Amazon KDP (no API - manual upload)
#
# For web projects:
# ☐ VERCEL_TOKEN (deployment)
# ☐ GITHUB_TOKEN (code)
#
# For library projects:
# ☐ NPM_TOKEN (JavaScript)
# ☐ PYPI_TOKEN (Python)
# ☐ GITHUB_TOKEN (code)
#
